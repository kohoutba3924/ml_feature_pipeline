    create  table
      "warehouse"."main"."stg_lcdv2_hourly__dbt_tmp"
  
    as (
      with source as (

    select
        station,
        timestamp,

        dry_bulb_temp,
        wet_bulb_temp,
        dew_point_temp,
        relative_humidity,

        wind_speed,
        wind_direction,
        wind_gust_speed,

        precipitation,
        visibility,

        station_pressure,
        barometric_pressure
    from "warehouse"."lcdv2"."hourly"

),

